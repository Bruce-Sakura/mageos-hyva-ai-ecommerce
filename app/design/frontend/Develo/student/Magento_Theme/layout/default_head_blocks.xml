<?xml version="1.0"?>
<!--
    Loads the Syne webfont (used for headings) from Google Fonts.
    preconnect hints speed up the font handshake; the stylesheet is loaded
    with display=swap so text stays visible while the font downloads.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <link src="https://fonts.googleapis.com"
              rel="preconnect"
              src_type="url"/>
        <link src="https://fonts.gstatic.com"
              rel="preconnect"
              crossorigin="anonymous"
              src_type="url"/>
        <link src="https://fonts.googleapis.com/css2?family=Syne:wght@400..800&amp;display=swap"
              rel="stylesheet"
              src_type="url"/>
    </head>
</page>
